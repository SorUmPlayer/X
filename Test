local RS = pcall(function()
    local remotes = ReplicatedStorage:FindFirstChild("AliensPowerRemotes")
    if remotes then
        return remotes:FindFirstChild("upgrade")
    end
end) and ReplicatedStorage:FindFirstChild("AliensPowerRemotes"):FindFirstChild("upgrade") or nil

local function Laser()
    if RS and RS.Laser then pcall(function() RS.Laser:InvokeServer() end) end
end
local function GunArm()
    if RS and RS.GunArm then pcall(function() RS.GunArm:InvokeServer() end) end
end
local function Armature()
    if RS and RS.Armature then pcall(function() RS.Armature:InvokeServer() end) end
end

local function ArmFire(targetRoot)
    if not RS or not RS.ArmFire then return end
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root then
        local targetPosition = targetRoot and targetRoot.Position or (root.Position + Vector3.new(0, -100, 0))
        pcall(function()
            RS.ArmFire:InvokeServer(targetPosition)
        end)
    end
end

-- =============================================
-- LÓGICA DE ALVO E TELEPORTE
-- =============================================
local function getLocalCharacter()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    return char, root
end

local function getClosestNPC()
    local _, myRoot = getLocalCharacter()
    if not myRoot then return nil end

    local enemysFolder = workspace:FindFirstChild("Enemys")
    if not enemysFolder then return nil end

    local closestNPC = nil
    local shortestDistance = math.huge

    for _, enemyFolder in ipairs(enemysFolder:GetChildren()) do
        local npcCharacter = enemyFolder:FindFirstChild("Character")
        if npcCharacter and npcCharacter:IsA("Model") then
            local npcRoot = npcCharacter:FindFirstChild("HumanoidRootPart")
            local npcHumanoid = npcCharacter:FindFirstChildOfClass("Humanoid")
            if npcRoot and npcHumanoid and npcHumanoid.Health > 0 then
                local distance = (myRoot.Position - npcRoot.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestNPC = npcRoot
                end
            end
        end
    end
    return closestNPC
end

local function ExecutarTeleporte(cframe)
    if estaTeleportando then return end
    estaTeleportando = true
    pcall(function()
        if LocalPlayer.Character then
            LocalPlayer.Character:PivotTo(cframe)
        end
    end)
    task.wait(0.1)
    estaTeleportando = false
end

local function MudarServidor(ordem)
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=" .. ordem .. "&limit=100"
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if type(server) == "table" and server.id ~= game.JobId then
                if server.playing > 0 and server.playing < server.maxPlayers then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                    return
                end
            end
        end
    end
end

-- =============================================
-- LOOP DA RAID – OTIMIZADO
-- =============================================
local raidConnection = nil

local function startRaidLoop()
    if raidConnection then return end
    raidConnection = RunService.Heartbeat:Connect(function()
        if not Config.RaidEnabled then
            if raidConnection then
                raidConnection:Disconnect()
                raidConnection = nil
            end
            return
        end

        local _, myRoot = getLocalCharacter()
        local targetNPC = getClosestNPC()
        if not myRoot or not targetNPC then return end

        -- Teleporta para o NPC (fixo)
        myRoot.CFrame = targetNPC.CFrame * CFrame.new(0, Config.NpcDistance, 0)

        -- Executa os disparos com multiplicador
        local multiplier = math.floor(tonumber(Config.ShotSpeedIndex) or 1)
        if multiplier > 0 then
            for i = 1, multiplier do
                if not Config.RaidEnabled then break end
                Laser()
                GunArm()
                ArmFire(targetNPC)
                Armature()
                task.wait() -- yield mínimo para não travar
            end
        end
    end)
end

-- Inicia automaticamente se a Raid estiver ativada
if Config.RaidEnabled then
    task.spawn(startRaidLoop)
end

