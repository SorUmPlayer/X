# Evoluir via select (menos poluído)
class EvoluirSelectView(discord.ui.View):
    def __init__(self, pd): super().__init__(timeout=120); self.pd = pd
        options = []
        for owned in pd["personagens"]:
            char = get_character(owned["id"])
            if char:
                options.append(discord.SelectOption(label=char["name"], value=str(owned["id"])))
        if options:
            self.select = discord.ui.Select(placeholder="Escolha o personagem", options=options)
            self.select.callback = self.evoluir_callback
            self.add_item(self.select)
    async def evoluir_callback(self, interaction):
        char_id = int(self.select.values[0])
        owned = next(c for c in self.pd["personagens"] if c["id"]==char_id)
        char = get_character(char_id)
        if owned["level"] >= char["evolution_max"]:
            return await interaction.response.send_message("❌ Nível máximo!", ephemeral=True)
        item = char["evo_item"]
        cost = 100 + owned["level"] * 30
        if item not in self.pd["itens"] or self.pd["money"] < cost:
            return await interaction.response.send_message("❌ Faltam recursos.", ephemeral=True)
        self.pd["itens"].remove(item)
        self.pd["money"] -= cost
        owned["level"] += 1
        save_data()
        await interaction.response.send_message(f"✅ {char['name']} evoluiu para nível {owned['level']}!", ephemeral=True)

