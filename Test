class CreateAccountModal(discord.ui.Modal, title="Criar Conta"):
    nick = discord.ui.TextInput(label="Nick", placeholder="Seu nick único")
    senha = discord.ui.TextInput(label="Senha", placeholder="Senha segura")
    async def on_submit(self, interaction):
        uid = str(interaction.user.id)
        nick = self.nick.value.strip()
        senha_hash = hashlib.sha256(self.senha.value.encode()).hexdigest()
        if any(u.get("nick")==nick for u in data["users"].values()):
            return await interaction.response.send_message("❌ Nick já existe!", ephemeral=True)
        pd = get_player(interaction.user.id)
        pd.update(nick=nick, senha_hash=senha_hash)
        for _ in range(4):
            char = random.choice(character_db)
            pd["personagens"].append({
                "id":char["id"],"level":0,"talento":get_random_talento(),"equipped_accessory":None
            })
        save_data()
        await interaction.response.send_message("✅ Conta criada! Escolha sua classe:", view=ClassChoiceView(), ephemeral=True)

class LoginModal(discord.ui.Modal, title="Fazer Login"):
    nick = discord.ui.TextInput(label="Nick")
    senha = discord.ui.TextInput(label="Senha")
    async def on_submit(self, interaction):
        uid = str(interaction.user.id)
        nick = self.nick.value.strip()
        senha_hash = hashlib.sha256(self.senha.value.encode()).hexdigest()
        pd = data["users"].get(uid)
        if pd and pd.get("nick")==nick and pd.get("senha_hash")==senha_hash:
            await interaction.response.send_message(f"✅ Bem-vindo, {nick}!", ephemeral=True)
        else:
            await interaction.response.send_message("❌ Nick ou senha incorretos!", ephemeral=True)

class InputNickModal(discord.ui.Modal, title="Informe o Nick"):
    nick = discord.ui.TextInput(label="Nick exato")
    def __init__(self, callback_func):
        super().__init__(); self.callback_func = callback_func
    async def on_submit(self, interaction):
        await self.callback_func(interaction, self.nick.value.strip())

