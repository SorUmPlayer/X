def populate_shop():
    shop_items = [it for it in items_db if random.random() <= 0.35]
    shop_acc = []
    for rarity, chance in [("Comum",0.70),("Raro",0.50),("Lendário",0.25),("Mítico",0.10),("Secreto",0.01)]:
        for acc in acessorios_db[rarity]:
            if random.random() <= chance:
                shop_acc.append(acc)
    data["shop_items"] = shop_items
    data["shop_accessories"] = shop_acc
    data["shop_reset_time"] = datetime.now().isoformat()
    save_data()

if not data.get("shop_reset_time"):
    populate_shop()

