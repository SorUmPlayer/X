@tasks.loop(minutes=5)
async def auto_reset_shop():
    if data["shop_reset_time"]:
        last = datetime.fromisoformat(data["shop_reset_time"])
        if (datetime.now() - last).total_seconds() >= data["config"]["shop_reset_minutes"] * 60:
            populate_shop()

@tasks.loop(seconds=20)
async def pvp_royal_matcher():
    queue = data.get("pvp_queue", [])
    if len(queue) >= 2:
        uid1, uid2 = queue.pop(0), queue.pop(0)
        data["pvp_queue"] = queue
        save_data()
        user1 = bot.get_user(int(uid1))
        user2 = bot.get_user(int(uid2))
        if not user1 or not user2:
            return
        winner = random.choice([uid1, uid2])
        loser = uid2 if winner == uid1 else uid1
        pd_winner = get_player(int(winner))
        pd_winner["vitorias"] += 1
        pd_winner["money"] += random.randint(1, 50)
        gain_xp(pd_winner, random.randint(1, 20))
        save_data()
        try:
            await user1.send(f"PvP Royal: Você {'venceu' if winner==uid1 else 'perdeu'}!")
            await user2.send(f"PvP Royal: Você {'venceu' if winner==uid2 else 'perdeu'}!")
        except:
            pass

@bot.event
async def on_ready():
    print(f"✅ {bot.user} online - Anime Battle Ultimate!")
    auto_reset_shop.start()
    pvp_royal_matcher.start()

