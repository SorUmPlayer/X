ranks_list = ["Bronze","Bronze 1","Bronze 2","Ferro","Ferro 1","Dourado","Dourado 1","Dourado 2","Dourado 3","Dourado 4","Dourado 5","Diamante","Diamante 1","Diamante 2","Diamante 3","Pena de Fênix 1","Pena de Fênix 2","Fênix"]

def get_rank(level, vitorias):
    score = (level * 8) + (vitorias * 6)
    return ranks_list[min(score // 55, len(ranks_list)-1)]

def gain_xp(player_dict, amount):
    player_dict["xp"] += amount
    leveled_up = False
    while player_dict["xp"] >= player_dict["xp_max"]:
        player_dict["level"] += 1
        player_dict["xp"] -= player_dict["xp_max"]
        leveled_up = True
        rank_idx = ranks_list.index(player_dict.get("rank","Bronze"))
        player_dict["xp_max"] += 200 if rank_idx >= 12 else 100
    player_dict["rank"] = get_rank(player_dict["level"], player_dict["vitorias"])
    return leveled_up

