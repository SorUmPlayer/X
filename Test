def get_character_stats(owned, char):
    talento = owned["talento"]
    acc = owned.get("equipped_accessory", None)
    acc_bonus = 15 if acc else 0
    strength = char["base_strength"] + (owned["level"] * 12) + talento.get("forca",0) + acc_bonus
    hp = char["base_hp"] + (owned["level"] * 8) + talento.get("hp",0) + talento.get("extra_hp",0)
    return int(strength), int(hp)

def get_character_details(owned, char):
    strength, hp = get_character_stats(owned, char)
    txt = f"**Nick:** {char['name']}\n"
    txt += f"**Anime:** {char['anime']} ({char['type'].upper()})\n"
    txt += f"**Força Total:** {strength} 🔥\n"
    txt += f"**HP:** {hp} ❤️\n"
    txt += f"**Evolução:** {owned['level']} / {char['evolution_max']}\n\n"
    txt += f"**Talento:**\n{get_talent_description(owned['talento'])}\n"
    txt += "**Extra**\n"
    txt += f"Ataque Especial → Level {owned['level']+1}\n"
    if char["evolution_max"] == 5:
        txt += f"Transformação → Chance {max(80 - owned['level']*10, 20)}%\n"
    if acc := owned.get("equipped_accessory"):
        for rar in acessorios_db.values():
            for a in rar:
                if a["name"] == acc:
                    txt += f"**Acessório:** {acc} ({a['effect']})\n"
    return txt

