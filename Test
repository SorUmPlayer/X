--[[
  SCRIPT VISUAL SAMURAI - AURA + ANIMAÇÃO + PHONK
  Coloque em StarterPlayerScripts ou StarterCharacterScripts
--]]

local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local humanoid = char:WaitForChild("Humanoid")
local runService = game:GetService("RunService")
local userInput = game:GetService("UserInputService")

-- VARIÁVEIS DE CONTROLE
local debounce = false
local ring = nil
local slashBeam = nil

-- =====================================================
-- 1. AURA (PARTÍCULAS DE FOGO SOMBRIO)
-- =====================================================
local function criarAura()
    local attach = Instance.new("Attachment")
    attach.Name = "AuraAttachment"
    attach.Parent = root

    local emitter = Instance.new("ParticleEmitter")
    emitter.Name = "SamuraiAura"
    emitter.Parent = attach
    
    -- Configuração visual (Vermelho / Preto / Laranja)
    emitter.Texture = "rbxasset://textures/particles/sparkles_main.dds"
    emitter.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 50, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(120, 0, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
    }
    emitter.Size = NumberSequence.new(2, 5)
    emitter.Transparency = NumberSequence.new(0.2, 0.9)
    emitter.SpreadAngle = Vector2.new(360, 360)
    emitter.VelocityInheritance = 0.3
    emitter.Lifetime = NumberRange.new(0.8, 1.5)
    emitter.Rate = 80
    emitter.Rotation = NumberRange.new(0, 360)
    emitter.Speed = NumberRange.new(5, 15)
    emitter.Enabled = true
end

-- =====================================================
-- 2. ANEL ROTATIVO (ESTILO PORTAL/RESSONÂNCIA)
-- =====================================================
local function criarAnel()
    ring = Instance.new("Part")
    ring.Name = "SamuraiRing"
    ring.Shape = Enum.PartType.Cylinder
    ring.Size = Vector3.new(8, 0.3, 8)
    ring.CFrame = root.CFrame * CFrame.new(0, -1, 0)
    ring.Anchored = true
    ring.CanCollide = false
    ring.Material = Enum.Material.Neon
    ring.Color = Color3.fromRGB(180, 0, 0)
    ring.Transparency = 0.4
    ring.Parent = workspace

    -- Efeito de brilho (ponto de luz)
    local glow = Instance.new("PointLight")
    glow.Parent = ring
    glow.Color = Color3.fromRGB(200, 0, 0)
    glow.Range = 10
    glow.Brightness = 2

    -- Loop de rotação
    runService.RenderStepped:Connect(function()
        if ring and ring.Parent then
            ring.CFrame = root.CFrame * CFrame.new(0, -1, 0) * CFrame.Angles(0, math.rad(1.5), 0)
        end
    end)
end

-- =====================================================
-- 3. ANIMAÇÃO MODIFICADA (POSTURA SAMURAI)
-- =====================================================
local function ativarPostura()
    -- Aumenta velocidade e pulo
    humanoid.WalkSpeed = 22
    humanoid.JumpPower = 65

    -- Inclina o tronco pra frente (postura de combate)
    local tweenService = game:GetService("TweenService")
    local objetivo = CFrame.Angles(math.rad(10), 0, 0) 
    
    -- Aplica a inclinação no HumanoidRootPart via tween
    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local tween = tweenService:Create(root, tweenInfo, {CFrame = root.CFrame * objetivo})
    tween:Play()

    -- Cria um rastro visual de "vento" nos braços (opcional, via Motor6D é complexo, 
    -- então faremos um efeito visual de lâmina pairando)
    local blade = Instance.new("Part")
    blade.Name = "BladeEffect"
    blade.Size = Vector3.new(0.5, 0.5, 5)
    blade.BrickColor = BrickColor.new("Bright red")
    blade.Material = Enum.Material.Neon
    blade.Anchored = true
    blade.CanCollide = false
    blade.Transparency = 0.3
    blade.Parent = workspace

    -- Anexa a lâmina na mão direita (simulação)
    local rightArm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand")
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = rightArm
    weld.Part1 = blade
    weld.Parent = blade
    -- Posiciona a lâmina para frente
    blade.CFrame = rightArm.CFrame * CFrame.new(0, -0.5, -2)

    -- Faz a lâmina pulsar
    spawn(function()
        while blade and blade.Parent do
            blade.Transparency = 0.2 + math.sin(tick() * 8) * 0.2
            blade.Size = Vector3.new(0.5, 0.5, 4 + math.sin(tick() * 5) * 0.5)
            wait(0.03)
        end
    end)

    return blade
end

-- =====================================================
-- 4. GOLPE IAIDO (SLASH ANIMADO)
-- =====================================================
local function executarCorte()
    if debounce then return end
    debounce = true

    -- Cria o arco do corte (um cilindro gigante que aparece e some)
    local arco = Instance.new("Part")
    arco.Name = "IaidoSlash"
    arco.Shape = Enum.PartType.Cylinder
    arco.Size = Vector3.new(0.5, 0.5, 0.5)
    arco.Material = Enum.Material.Neon
    arco.Color = Color3.fromRGB(255, 50, 0)
    arco.Anchored = true
    arco.CanCollide = false
    arco.Transparency = 0.2
    arco.Parent = workspace

    -- Posiciona na frente do jogador
    local pos = root.CFrame * CFrame.new(0, 1, -4) * CFrame.Angles(math.rad(90), 0, 0)
    arco.CFrame = pos

    -- Anima o corte (cresce de 0 até 10 de comprimento e gira)
    local tweenService = game:GetService("TweenService")
    
    -- Crescimento
    local grow = tweenService:Create(arco, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = Vector3.new(8, 0.5, 0.5)
    })
    grow:Play()

    -- Rotação (simula o movimento da katana)
    local rotacao = tweenService:Create(arco, TweenInfo.new(0.3, Enum.EasingStyle.Linear), {
        CFrame = pos * CFrame.Angles(0, math.rad(-120), 0)
    })
    rotacao:Play()

    -- Efeito de partículas no golpe
    local atkAttach = Instance.new("Attachment")
    atkAttach.Parent = arco
    local atkParticle = Instance.new("ParticleEmitter")
    atkParticle.Parent = atkAttach
    atkParticle.Texture = "rbxasset://textures/particles/smoke_main.dds"
    atkParticle.Color = ColorSequence.new(Color3.fromRGB(255, 100, 0))
    atkParticle.Size = NumberSequence.new(3)
    atkParticle.Lifetime = NumberRange.new(0.5)
    atkParticle.Rate = 200
    atkParticle.SpreadAngle = Vector2.new(45, 45)
    atkParticle.Speed = NumberRange.new(10)

    -- Limpa o arco depois de 0.5s
    wait(0.5)
    arco:Destroy()

    -- Vibração da tela (simulação)
    local cam = workspace.CurrentCamera
    local originalCF = cam.CFrame
    for i = 1, 5 do
        cam.CFrame = cam.CFrame * CFrame.Angles(math.rad(math.random(-2,2)), math.rad(math.random(-2,2)), 0)
        wait(0.02)
    end
    cam.CFrame = originalCF

    debounce = false
end

-- =====================================================
-- 5. MÚSICA PHONK DE FUNDO
-- =====================================================
local function tocarPhonk()
    local sound = Instance.new("Sound")
    sound.Name = "PhonkMusic"
    sound.Volume = 0.7
    sound.Looped = true
    
    -- ⚠️ TROQUE ESSE ID POR UMA MÚSICA PHONK DA BIBLIOTECA DO ROBLOX ⚠️
    -- Exemplo de IDs: "rbxassetid://1841131629" (Bass) ou procure por "Phonk" no Toolbox
    sound.SoundId = "rbxassetid://6733393355" 
    
    sound.Parent = workspace
    sound:Play()
    
    -- Efeito de equalização visual (opcional: baixa a música se perder vida)
    sound:SetAttribute("Modo", "Samurai")
end

-- =====================================================
-- 6. INPUT (CLICK OU TECLA 'E' PARA CORTAR)
-- =====================================================
userInput.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.KeyCode == Enum.KeyCode.E then
        executarCorte()
    end
end)

-- =====================================================
-- 7. INICIALIZAÇÃO
-- =====================================================
criarAura()
criarAnel()
local minhaBlade = ativarPostura()
tocarPhonk()

print("⚔️ Modo Samurai Ativado! Clique ou aperte 'E' para dar o corte Iaido.")
