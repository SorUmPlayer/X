local RS = pcall(function()
    local remotes = ReplicatedStorage:FindFirstChild("AliensPowerRemotes")
    if remotes then
        return remotes:FindFirstChild("upgrade")
    end
end) and ReplicatedStorage:FindFirstChild("AliensPowerRemotes"):FindFirstChild("upgrade") or nil

local function Laser()
    if RS and RS.Laser then pcall(function() RS.Laser:InvokeServer() end) end
end
local function GunArm()
    if RS and RS.GunArm then pcall(function() RS.GunArm:InvokeServer() end) end
end
local function Armature()
    if RS and RS.Armature then pcall(function() RS.Armature:InvokeServer() end) end
end

local function ArmFire(targetRoot)
    if not RS or not RS.ArmFire then return end
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root then
        local targetPosition = targetRoot and targetRoot.Position or (root.Position + Vector3.new(0, -100, 0))
        pcall(function()
            RS.ArmFire:InvokeServer(targetPosition)
        end)
    end
end

-- =============================================
-- LÓGICA DE ALVO E TELEPORTE
-- =============================================
local function getLocalCharacter()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    return char, root
end

local function getClosestNPC()
    local _, myRoot = getLocalCharacter()
    if not myRoot then return nil end

    local enemysFolder = workspace:FindFirstChild("Enemys")
    if not enemysFolder then return nil end

    local closestNPC = nil
    local shortestDistance = math.huge

    for _, enemyFolder in ipairs(enemysFolder:GetChildren()) do
        local npcCharacter = enemyFolder:FindFirstChild("Character")
        if npcCharacter and npcCharacter:IsA("Model") then
            local npcRoot = npcCharacter:FindFirstChild("HumanoidRootPart")
            local npcHumanoid = npcCharacter:FindFirstChildOfClass("Humanoid")
            if npcRoot and npcHumanoid and npcHumanoid.Health > 0 then
                local distance = (myRoot.Position - npcRoot.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestNPC = npcRoot
                end
            end
        end
    end
    return closestNPC
end

local function ExecutarTeleporte(cframe)
    if estaTeleportando then return end
    estaTeleportando = true
    pcall(function()
        if LocalPlayer.Character then
            LocalPlayer.Character:PivotTo(cframe)
        end
    end)
    task.wait(0.1)
    estaTeleportando = false
end

local function MudarServidor(ordem)
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=" .. ordem .. "&limit=100"
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if type(server) == "table" and server.id ~= game.JobId then
                if server.playing > 0 and server.playing < server.maxPlayers then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                    return
                end
            end
        end
    end
end

-- =============================================
-- LOOP DA RAID (existente)
-- =============================================
local raidRunning = false
local raidConnection = nil

local function startRaidLoop()
    if raidConnection then return end
    raidRunning = true
    raidConnection = RunService.Heartbeat:Connect(function()
        if not Config.RaidEnabled then
            raidRunning = false
            if raidConnection then
                raidConnection:Disconnect()
                raidConnection = nil
            end
            return
        end

        local _, myRoot = getLocalCharacter()
        local targetNPC = getClosestNPC()
        if not myRoot or not targetNPC then return end

        myRoot.CFrame = targetNPC.CFrame * CFrame.new(0, Config.NpcDistance, 0)

        local multiplier = math.floor(tonumber(Config.ShotSpeedIndex) or 1)
        if multiplier > 0 then
            for i = 1, multiplier do
                if not Config.RaidEnabled then break end
                Laser()
                GunArm()
                ArmFire(targetNPC)
                Armature()
                task.wait()
            end
        end
    end)
end

if Config.RaidEnabled then
    task.spawn(startRaidLoop)
end

-- =============================================
-- LOOP DOS BOSSES (CORRIGIDO)
-- =============================================
local bossRunning = false
local bossConnection = nil

-- Função melhorada para obter a parte alvo do boss ativo
local function getActiveBossTarget()
    local enemys = workspace:FindFirstChild("Enemys")
    if not enemys then return nil end

    -- Lista de bosses com seus caminhos e chaves de configuração
    local bosses = {
        { configKey = "BossShip", folderName = "Ship [ Ferris Wheel Form ]", charName = "Character" },
        { configKey = "BossKraken", folderName = "Kraken", charName = "Character" },
        { configKey = "BossTransDimensional", folderName = "Trans Dimensional Monster", charName = "Character" },
    }

    for _, boss in ipairs(bosses) do
        if Config[boss.configKey] then
            local folder = enemys:FindFirstChild(boss.folderName)
            if folder then
                local char = folder:FindFirstChild(boss.charName)
                if char and char:IsA("Model") then
                    -- Tenta obter HumanoidRootPart ou Torso ou qualquer BasePart
                    local part = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                    if not part then
                        for _, child in ipairs(char:GetChildren()) do
                            if child:IsA("BasePart") then
                                part = child
                                break
                            end
                        end
                    end
                    if part and part:IsA("BasePart") then
                        return part
                    end
                end
            end
        end
    end
    return nil
end

local function startBossLoop()
    if bossConnection then return end
    bossRunning = true
    bossConnection = RunService.Heartbeat:Connect(function()
        -- Verifica se algum boss está ativo
        if not (Config.BossShip or Config.BossKraken or Config.BossTransDimensional) then
            bossRunning = false
            if bossConnection then
                bossConnection:Disconnect()
                bossConnection = nil
            end
            return
        end

        local targetPart = getActiveBossTarget()
        if not targetPart then return end

        local _, myRoot = getLocalCharacter()
        if not myRoot then return end

        -- Teleporte fixo para o boss
        myRoot.CFrame = targetPart.CFrame * CFrame.new(0, Config.BossDistance, 0)

        -- Disparos com multiplicador
        local multiplier = math.floor(tonumber(Config.BossShotMultiplier) or 1)
        if multiplier > 0 then
            for i = 1, multiplier do
                if not (Config.BossShip or Config.BossKraken or Config.BossTransDimensional) then break end
                Laser()
                GunArm()
                ArmFire(targetPart)
                Armature()
                task.wait()
            end
        end
    end)
end

-- Inicia o loop dos bosses se algum estiver ativo ao carregar
if Config.BossShip or Config.BossKraken or Config.BossTransDimensional then
    task.spawn(startBossLoop)
end

-- =============================================
-- ANTI‑AFK
-- =============================================
local antiAFKRunning = false
local antiAFKConnection = nil

local function startAntiAFK()
    if antiAFKConnection then return end
    antiAFKRunning = true
    antiAFKConnection = task.spawn(function()
        while antiAFKRunning and Config.AntiAFK do
            task.wait(60)
            if not Config.AntiAFK then break end
            pcall(function()
                local viewport = workspace.CurrentCamera.ViewportSize
                local center = Vector2.new(viewport.X/2, viewport.Y/2)
                VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 0)
                task.wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 0)
            end)
        end
        antiAFKConnection = nil
    end)
end

if Config.AntiAFK then
    task.spawn(startAntiAFK)
end

