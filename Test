-- =============================================
-- SALVAMENTO E CARREGAMENTO
-- =============================================
local function SaveConfig()
    if not writefile then return end
    local success, json = pcall(function()
        return HttpService:JSONEncode(Config)
    end)
    if success then
        pcall(function() writefile(FILE_NAME, json) end)
    end
end

local function LoadConfig()
    if not isfile then return end
    if isfile(FILE_NAME) then
        local success, data = pcall(function()
            return readfile(FILE_NAME)
        end)
        if success then
            local decoded = pcall(function() return HttpService:JSONDecode(data) end)
            if decoded and type(decoded) == "table" then
                for k, v in pairs(decoded) do
                    Config[k] = v
                end
                print("Configurações carregadas:", 
                    "Raid="..tostring(Config.RaidEnabled),
                    "Multi="..Config.ShotSpeedIndex,
                    "Dist="..Config.NpcDistance,
                    "Idioma="..Config.Language,
                    "SemIntro="..tostring(Config.RemoverIntro)
                )
            end
        end
    end
end
pcall(LoadConfig)

