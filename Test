def get_random_talento():
    r = random.random()
    if r < 0.70: rarity = "Comum"
    elif r < 0.90: rarity = "Raro"
    elif r < 0.95: rarity = "Lendário"
    elif r < 0.99: rarity = "Mítico"
    else: rarity = "Secreto"
    talento = random.choice(talents_db[rarity]).copy()
    talento["rarity"] = rarity
    return talento

def get_talent_description(talento):
    rarity = talento.get("rarity", "Comum")
    desc = f"**{talento['name']}** ({rarity})\n"
    if talento.get("forca"): desc += f"🔥 Força: {'+' if talento['forca']>0 else ''}{talento['forca']}\n"
    if talento.get("hp"): desc += f"❤️ HP: {'+' if talento['hp']>0 else ''}{talento['hp']}\n"
    if talento.get("esquivar"): desc += f"🛡️ Esquivar: +{talento['esquivar']}%\n"
    if talento.get("extra_hp"): desc += f"❤️ Extra HP por partida: +{talento['extra_hp']}\n"
    if talento.get("extra_acessorio"): desc += "✨ Permite equipar 2 acessórios\n"
    return desc.strip()

