# Tratamento de interações de botões dinâmicos (compra, seleção, etc.) sem on_interaction
@bot.listen("on_interaction")
async def interaction_handler(interaction):
    if interaction.type != discord.InteractionType.component:
        return
    custom_id = interaction.data.get("custom_id", "")
    pd = get_player(interaction.user.id)
    # Detalhes de personagem
    if custom_id.startswith("detail_"):
        char_id = int(custom_id.split("_")[1])
        owned = next((c for c in pd["personagens"] if c["id"]==char_id), None)
        if owned:
            char = get_character(char_id)
            embed = discord.Embed(title=char["name"], description=get_character_details(owned, char))
            await interaction.response.send_message(embed=embed, ephemeral=True)
    # Equipar slot
    elif custom_id.startswith("equip_"):
        slot_idx = int(custom_id.split("_")[1])
        view = discord.ui.View(timeout=60)
        for owned in pd["personagens"]:
            char = get_character(owned["id"])
            view.add_item(discord.ui.Button(label=char["name"], style=discord.ButtonStyle.primary, custom_id=f"equip_{slot_idx}_{owned['id']}"))
        await interaction.response.send_message("Escolha o personagem:", view=view, ephemeral=True)
    elif custom_id.startswith("equip_") and len(custom_id.split("_"))==3:
        _, slot_idx, char_id = custom_id.split("_")
        slot_idx = int(slot_idx); char_id = int(char_id)
        pd["slots"][slot_idx] = {"id":char_id}
        save_data()
        await interaction.response.send_message("Equipado!", ephemeral=True)
    # Acessórios
    elif custom_id.startswith("acc_"):
        acc_name = custom_id[4:]
        if acc_name not in pd["acessorios"]:
            return await interaction.response.send_message("Acessório não encontrado.", ephemeral=True)
        view = discord.ui.View(timeout=60)
        for i, slot in enumerate(pd["slots"]):
            if slot:
                char = get_character(slot["id"])
                view.add_item(discord.ui.Button(label=char["name"], style=discord.ButtonStyle.primary, custom_id=f"equipacc_{i}_{acc_name}"))
        await interaction.response.send_message("Escolha o personagem:", view=view, ephemeral=True)
    elif custom_id.startswith("equipacc_"):
        _, slot_idx, acc_name = custom_id.split("_",2)
        slot_idx = int(slot_idx)
        slot = pd["slots"][slot_idx]
        if not slot: return
        owned = next(c for c in pd["personagens"] if c["id"]==slot["id"])
        if owned.get("equipped_accessory"): return await interaction.response.send_message("Já tem acessório.", ephemeral=True)
        owned["equipped_accessory"] = acc_name
        pd["acessorios"].pop(acc_name, None)
        save_data()
        await interaction.response.send_message("Acessório equipado!", ephemeral=True)
    # Desequipar
    elif custom_id.startswith("uneq_"):
        char_id = int(custom_id[5:])
        owned = next(c for c in pd["personagens"] if c["id"]==char_id)
        if owned.get("equipped_accessory"):
            acc = owned.pop("equipped_accessory")
            pd["acessorios"][acc] = {"name":acc}
            save_data()
            await interaction.response.send_message("Desequipado!", ephemeral=True)
    # Compras da loja (item)
    elif custom_id.startswith("buy_"):
        item_name = custom_id[4:]
        if item_name in [i["name"] for i in data["shop_items"]]:
            item = next(i for i in data["shop_items"] if i["name"]==item_name)
            if pd["money"] >= item["price"]:
                pd["money"] -= item["price"]
                pd["itens"].append(item["name"])
                data["shop_items"].remove(item)
                save_data()
                await interaction.response.send_message(f"✅ Comprou {item['name']}!", ephemeral=True)
            else:
                await interaction.response.send_message("❌ Dinheiro insuficiente.", ephemeral=True)
    elif custom_id.startswith("buyacc_"):
        acc_name = custom_id[7:]
        if acc_name in [a["name"] for a in data["shop_accessories"]]:
            acc = next(a for a in data["shop_accessories"] if a["name"]==acc_name)
            if pd["money"] >= acc["price"]:
                pd["money"] -= acc["price"]
                pd["acessorios"][acc["name"]] = acc
                data["shop_accessories"].remove(acc)
                save_data()
                await interaction.response.send_message(f"✅ Comprou {acc['name']}!", ephemeral=True)
            else:
                await interaction.response.send_message("❌ Dinheiro insuficiente.", ephemeral=True)
    elif custom_id.startswith("caixa_"):
        ctype = custom_id[6:]
        caixa = next((c for c in caixas_db if c["type"]==ctype), None)
        if caixa and pd["money"] >= caixa["price"]:
            pd["money"] -= caixa["price"]
            if ctype == "personagem":
                char = random.choice(character_db)
                pd["personagens"].append({"id":char["id"],"level":0,"talento":get_random_talento(),"equipped_accessory":None})
                msg = f"🎉 Ganhou **{char['name']}**!"
            elif ctype == "item":
                item = random.choice(items_db)
                pd["itens"].append(item["name"])
                msg = f"🎉 Ganhou **{item['name']}**!"
            else:
                acc = random.choice([a for lst in acessorios_db.values() for a in lst])
                pd["acessorios"][acc["name"]] = acc
                msg = f"🎉 Ganhou **{acc['name']}**!"
            save_data()
            await interaction.response.send_message(msg, ephemeral=True)
        else:
            await interaction.response.send_message("❌ Dinheiro insuficiente.", ephemeral=True)
    elif custom_id.startswith("vara_"):
        nome = custom_id[5:]
        if nome in varas_db and "price" in varas_db[nome] and pd["money"] >= varas_db[nome]["price"]:
            pd["money"] -= varas_db[nome]["price"]
            pd["vara"] = nome
            save_data()
            await interaction.response.send_message(f"✅ Vara {nome} comprada!", ephemeral=True)
        else:
            await interaction.response.send_message("❌ Erro.", ephemeral=True)

